<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">
 
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_events"
        android:textColor="@color/accent"
        android:textSize="12sp"
        android:letterSpacing="0.3"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="12dp" />
 
    <EditText
        android:id="@+id/search_box"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:hint="Search events..."
        android:textColor="@color/text_primary"
        android:textColorHint="#55FFFFFF"
        android:textSize="14sp"
        android:singleLine="true"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:background="@drawable/search_bg"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:drawableTint="@color/text_muted" />
 
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/event_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />
 
    <com.google.android.material.button.MaterialButton
        android:id="@+id/save_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/save"
        android:enabled="false" />
 
    <LinearLayout
        android:id="@+id/perm_prompt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">
 
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calendar_permission"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />
 
        <com.google.android.material.button.MaterialButton
            android:id="@+id/perm_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/grant_permission" />
    </LinearLayout>
</LinearLayout>
 
